# Copy this to `.env` (used by both `npm run dev` and `docker compose`).
# Next.js auto-loads `.env`; docker-compose reads it for variable substitution.

# Postgres connection string. The default value works for `npm run dev`
# (talks to the docker-compose Postgres on the host's published port).
# When the web service runs inside docker-compose, this is overridden to
# `postgres://postgres:postgres@db:5432/wikids` so it uses the compose network.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wikids

# Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string

# Public URL where the app is served. Used by Auth.js for callback URLs.
AUTH_URL=http://localhost:3000
