# Postgres connection string used by Drizzle and the app at runtime.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wikids

# Auth.js secret. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string

# URL where the app is served. Used by Auth.js for callbacks.
AUTH_URL=http://localhost:3000
